{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python build_site_data.py",
  "outputDirectory": "site",
  "headers": [
    {
      "source": "/data.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
